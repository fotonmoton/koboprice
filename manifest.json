{
  "name": "Kobo Price",
  "description": "Compare ebook & audiobook prices across all Kobo stores, sorted and converted to USD.",
  "version": "1.5.0",
  "manifest_version": 3,
  "content_scripts": [
    {
      "js": ["dist/index.js"],
      "run_at": "document_end",
      "matches": [
        "https://www.kobo.com/*/*/ebook/*",
        "https://www.kobo.com/*/*/audiobook/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "koboprice@tertyshny.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
